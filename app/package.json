    "bcryptjs": "^3.0.3",
    "isbot": "^5.1.36",
    "lucide-react": "^1.16.0",
    "papaparse": "^5.5.3",
    "prisma": "^6.19.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "7.15.1",
    "tsx": "^4.22.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@react-router/dev": "7.15.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/react-router": "^1.3.0",
    "tailwindcss": "^4.2.2",
